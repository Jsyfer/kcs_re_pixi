{
    "compilerOptions": {
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "ignoreDeprecations": "6.0",
        "baseUrl": "src",
        "paths": {
            "@/*": [
                "*"
            ],
            "@common/*": [
                "common/*"
            ],
            "@loading/*": [
                "loading/*"
            ],
            "@scene/*": [
                "scene/*"
            ],
            "@ship/*": [
                "ship/*"
            ]
        }
    },
    "exclude": [
        "node_modules",
        "dist",
        "assets",
        "backend",
        "api",
        "old",
        "sql"
    ]
}